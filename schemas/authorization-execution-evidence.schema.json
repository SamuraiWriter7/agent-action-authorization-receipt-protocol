{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:kazene:agent-action-authorization-receipt-protocol:authorization-execution-evidence:0.4.0",
  "title": "Authorization Execution Evidence",
  "description": "Evidence recording whether an attempted AI agent execution matched an authorization receipt.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "execution_evidence_id",
    "authorization_id",
    "request_id",
    "agent_id",
    "execution_id",
    "execution_status",
    "observed_action",
    "authorization_match",
    "execution_usage",
    "started_at",
    "completed_at",
    "outcome_refs",
    "recorded_at"
  ],
  "properties": {
    "schema_version": {
      "const": "0.4.0"
    },
    "execution_evidence_id": {
      "$ref": "#/$defs/identifier"
    },
    "authorization_id": {
      "$ref": "#/$defs/identifier"
    },
    "request_id": {
      "$ref": "#/$defs/identifier"
    },
    "agent_id": {
      "$ref": "#/$defs/identifier"
    },
    "execution_id": {
      "$ref": "#/$defs/identifier"
    },
    "execution_status": {
      "type": "string",
      "enum": [
        "started",
        "succeeded",
        "failed",
        "blocked",
        "cancelled"
      ]
    },
    "observed_action": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "action_type",
        "tool_id",
        "target_id",
        "destination_id",
        "data_classes",
        "actual_cost",
        "actual_duration_seconds",
        "parameters_digest"
      ],
      "properties": {
        "action_type": {
          "$ref": "#/$defs/action_type"
        },
        "tool_id": {
          "oneOf": [
            {
              "$ref": "#/$defs/identifier"
            },
            {
              "type": "null"
            }
          ]
        },
        "target_id": {
          "oneOf": [
            {
              "$ref": "#/$defs/identifier"
            },
            {
              "type": "null"
            }
          ]
        },
        "destination_id": {
          "oneOf": [
            {
              "$ref": "#/$defs/identifier"
            },
            {
              "type": "null"
            }
          ]
        },
        "data_classes": {
          "$ref": "#/$defs/identifier_array"
        },
        "actual_cost": {
          "oneOf": [
            {
              "$ref": "#/$defs/money"
            },
            {
              "type": "null"
            }
          ]
        },
        "actual_duration_seconds": {
          "oneOf": [
            {
              "type": "integer",
              "minimum": 0
            },
            {
              "type": "null"
            }
          ]
        },
        "parameters_digest": {
          "oneOf": [
            {
              "type": "string",
              "pattern": "^sha256:[A-Fa-f0-9]{64}$"
            },
            {
              "type": "null"
            }
          ]
        }
      }
    },
    "authorization_match": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "checked_by",
        "checked_at",
        "violations"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "matched",
            "mismatched"
          ]
        },
        "checked_by": {
          "$ref": "#/$defs/identifier"
        },
        "checked_at": {
          "type": "string",
          "format": "date-time"
        },
        "violations": {
          "type": "array",
          "maxItems": 32,
          "items": {
            "$ref": "#/$defs/violation"
          }
        }
      }
    },
    "execution_usage": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "consumed",
        "sequence_number",
        "used_before",
        "used_after"
      ],
      "properties": {
        "consumed": {
          "type": "boolean"
        },
        "sequence_number": {
          "type": "integer",
          "minimum": 1
        },
        "used_before": {
          "type": "integer",
          "minimum": 0
        },
        "used_after": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "started_at": {
      "oneOf": [
        {
          "type": "string",
          "format": "date-time"
        },
        {
          "type": "null"
        }
      ]
    },
    "completed_at": {
      "oneOf": [
        {
          "type": "string",
          "format": "date-time"
        },
        {
          "type": "null"
        }
      ]
    },
    "outcome_refs": {
      "$ref": "#/$defs/reference_array"
    },
    "recorded_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "$defs": {
    "identifier": {
      "type": "string",
      "minLength": 3,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]*$"
    },
    "reference": {
      "type": "string",
      "minLength": 3,
      "maxLength": 256,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/#-]*$"
    },
    "action_type": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]*$"
    },
    "money": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "currency",
        "amount"
      ],
      "properties": {
        "currency": {
          "type": "string",
          "pattern": "^[A-Z]{3}$"
        },
        "amount": {
          "type": "string",
          "pattern": "^(0|[1-9][0-9]*)(\\.[0-9]{1,6})?$"
        }
      }
    },
    "identifier_array": {
      "type": "array",
      "maxItems": 64,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/identifier"
      }
    },
    "reference_array": {
      "type": "array",
      "maxItems": 64,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/reference"
      }
    },
    "violation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "code",
        "field",
        "expected",
        "observed"
      ],
      "properties": {
        "code": {
          "type": "string",
          "enum": [
            "decision_blocking",
            "receipt_expired",
            "authorization_revoked",
            "request_mismatch",
            "agent_mismatch",
            "action_type_out_of_scope",
            "tool_out_of_scope",
            "resource_out_of_scope",
            "data_class_out_of_scope",
            "destination_out_of_scope",
            "cost_limit_exceeded",
            "duration_limit_exceeded",
            "execution_count_exceeded",
            "prohibited_action",
            "parameters_digest_mismatch"
          ]
        },
        "field": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        "expected": {
          "oneOf": [
            {
              "type": "string",
              "maxLength": 512
            },
            {
              "type": "null"
            }
          ]
        },
        "observed": {
          "oneOf": [
            {
              "type": "string",
              "maxLength": 512
            },
            {
              "type": "null"
            }
          ]
        }
      }
    }
  }
}
